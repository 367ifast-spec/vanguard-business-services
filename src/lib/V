import { cookies } from "next/headers";
import { randomUUID } from "crypto";

const CART_COOKIE = "vanguard_cart_session";

export async function getCartSessionId(): Promise<string> {
  const cookieStore = await cookies();

  const existing = cookieStore.get(CART_COOKIE);

  if (existing?.value) {
    return existing.value;
  }

  const sessionId = randomUUID();

  cookieStore.set(CART_COOKIE, sessionId, {
    httpOnly: true,
    secure: process.env.NODE_ENV === "production",
    sameSite: "lax",
    path: "/",
    maxAge: 60 * 60 * 24 * 30, // 30 days
  });

  return sessionId;
}

export async function clearCartSession(): Promise<void> {
  const cookieStore = await cookies();

  cookieStore.delete(CART_COOKIE);
}